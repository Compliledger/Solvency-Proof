{
  "name": "@solvencyproof/algorand",
  "version": "0.1.0",
  "private": true,
  "description": "Algorand Solvent Registry — smart contract, client, and types for SolvencyProof Phase 2",
  "type": "module",
  "exports": {
    "./types": "./types/registry.js",
    "./client": "./client/registry_client.js"
