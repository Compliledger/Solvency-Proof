# SolvencyProof Environment Configuration

# ============================================================
# Algorand Configuration
# ============================================================

# Algorand testnet node (free public endpoint)
ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud

# Algorand mainnet (production)
# ALGORAND_NODE_URL=https://mainnet-api.algonode.cloud
# ALGORAND_INDEXER_URL=https://mainnet-idx.algonode.cloud

# SolventRegistry application ID (obtained after deploying the contract)
# Run: npx tsx algorand/scripts/deploy-contract.ts
SOLVENT_REGISTRY_APP_ID=

# Algorand account mnemonic (25 words) for signing transactions
# ⚠️ KEEP THIS SECRET - Never commit to git
# Get testnet ALGO from: https://bank.testnet.algorand.network/
ALGO_MNEMONIC=

# ============================================================
# Backend Configuration
# ============================================================

# Backend API server port
PORT=3001
API_PORT=3001

# Entity identifier for solvency proofs
ENTITY_ID=compliledger-entity-01

# ============================================================
# Ethereum Configuration (Legacy - for backwards compatibility)
# ============================================================

# Private key for Ethereum transactions (0x prefixed)
PRIVATE_KEY=

# Ethereum RPC URL
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ============================================================
# Yellow Network Configuration
# ============================================================

YELLOW_API_URL=https://api.yellow.org
YELLOW_API_KEY=
